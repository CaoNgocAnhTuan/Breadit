sequenceDiagram
    autonumber
    actor       UserA as Sender (User A)
    actor       UserB as Receiver (User B)
    participant FE_A  as Frontend A<br/>(Sender Next.js)
    participant FE_B  as Frontend B<br/>(Receiver Next.js)
    participant BE    as Backend Gateways<br/>(NestJS)
    participant DB    as Database

    %% ── Phase 1: Open Chat & Join Room ─────────────────────────────
    rect rgb(224, 242, 254)
        Note over UserA,DB: Phase 1 — Open Chat & Join Room

        UserA ->>+ FE_A : Click message on User B's profile
        FE_A ->>+ BE : POST /api/conversations { targetUserId }
        Note over BE : JwtAuthGuard + EmailVerifiedGuard + block check

        BE ->>+ DB : Check block pair & create/fetch conversation
        DB -->>- BE : Conversation record (conversationId)
        BE -->>- FE_A : 200 OK — Conversation JSON

        FE_A ->>+ BE : GET /api/conversations/:id/messages
        BE ->>+ DB : Query messages list & set user lastReadAt
        DB -->>- BE : Message history list
        BE -->>- FE_A : 200 OK — Messages page

        FE_A -) BE : Socket.io emit 'joinConversation' { conversationId }
        
        FE_A -) BE : PATCH /api/conversations/:id/read (mark read)
        BE ->>+ DB : Update conversation membership lastReadAt
        DB -->>- BE : Success
        
        FE_A -->>- UserA : Render conversation UI & initial message list
    end

    %% ── Phase 2: Typing Indicators ─────────────────────────────────
    rect rgb(254, 243, 199)
        Note over UserA,DB: Phase 2 — Typing Indicators

        UserA ->> FE_A : Start typing in message bar
        FE_A -) BE : Socket.io emit 'startTyping' { conversationId, username }
        BE -) +FE_B : Socket.io broadcast 'userTyping' to room conversationId
        FE_B -->>- UserB : Render typing indicator (dots)
    end

    %% ── Phase 3: Send & Deliver Message ────────────────────────────
    rect rgb(236, 253, 245)
        Note over UserA,DB: Phase 3 — Send & Deliver Message

        UserA ->>+ FE_A : Type text message & press Send
        FE_A -) BE : Socket.io emit 'stopTyping' { conversationId }
        BE -) +FE_B : Socket.io broadcast 'userStopTyping' to room
        FE_B -->>- UserB : Hide typing indicator

        FE_A ->>+ BE : POST /api/conversations/:id/messages { body }
        Note over BE : JwtAuthGuard + EmailVerifiedGuard
        
        BE ->>+ DB : Create Message & update Conversation updatedAt (transaction)
        DB -->>- BE : Message record
        
        BE ->> BE : Invalidate unreadCount cache for User B
        BE -) +FE_B : Socket.io emit 'newMessage' { conversationId, message, sender }
        
        BE -->>- FE_A : 201 Created — Message JSON
        FE_A -->>- UserA : Append message to local thread list
        FE_B -->>- UserB : Receive and append message to thread list
    end
