sequenceDiagram
    autonumber
    actor       User as User
    participant FE    as Frontend<br/>(Next.js)
    participant BE    as Backend<br/>(NestJS)
    participant Cache as Redis Cache
    participant DB    as Database

    %% ── Phase 1: Browse Feed ───────────────────────────────────────
    rect rgb(224, 242, 254)
        Note over User,DB: Phase 1 — Browse Feed

        User ->>+ FE : Select tab: For You | Explore | Following | Communities
        FE   ->>+ BE : GET /api/posts?feed={mode}&cursor={cursor}
        BE   ->>+ Cache: Check feed cache
        Cache -->>- BE : Hit / Miss

        alt Cache hit
            BE -->> FE : 200 OK — { posts, hasMore, nextCursor }
        else Cache miss
            alt feed = "explore"
                BE ->>+ DB : Get posts from the last 7 days
                DB -->>- BE : Raw rows
                BE ->>  BE : Score & rank: likes + comments×2 + reposts×3 − age×0.25<br/>→ Diversity filter (max 3/author) → Slice 10
            else feed = "following"
                BE ->>+ Cache: Get followingIds (TTL 5min)
                Cache -->>- BE : followingIds[]
                BE ->>+ DB : Posts where userId IN followingIds
                DB -->>- BE : Post rows
            else feed = "communities"
                BE ->>+ Cache: Get communityIds (TTL 5min)
                Cache -->>- BE : communityIds[]
                BE ->>+ DB : Posts where communityId IN communityIds
                DB -->>- BE : Post rows
            else For You / Guest
                BE ->>+ DB : Posts where userId IN [self, followees]<br/>or all public posts (guest)
                DB -->>- BE : Post rows
            end
            BE    ->>  Cache: Save cache (TTL 10s)
            BE   -->>- FE : 200 OK — { posts, hasMore, nextCursor }
        end

        FE -->>- User : Render feed + infinite scroll
    end

    %% ── Phase 2: Search Content ────────────────────────────────────
    rect rgb(236, 253, 245)
        Note over User,DB: Phase 2 — Search Content

        User ->>+ FE : Enter keyword → /search?q={query}
        FE   ->>+ BE : GET /api/search?q={query}
        BE   ->>+ Cache: Check search cache
        Cache -->>- BE : Hit / Miss

        alt Cache hit
            BE -->> FE : 200 OK — { posts, users, hashtags, communities }
        else Cache miss
            BE ->>+ DB : Promise.all 4 queries (case-insensitive, limit 5 each):<br/>posts · users · hashtags · communities
            DB -->>- BE : Combined results
            BE ->>  Cache: Save cache (TTL 10s)
            BE -->>- FE : 200 OK — { posts, users, hashtags, communities }
        end

        alt No results
            FE -->> User: "No results for ..."
        else Has results
            FE -->>- User: Render by group: People · Hashtags · Communities · Posts
        end
    end