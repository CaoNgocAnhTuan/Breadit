sequenceDiagram
    autonumber
    actor       User as User
    participant FE    as Frontend<br/>(Next.js)
    participant BE    as Backend<br/>(NestJS)
    participant DB    as Database

    %% ── Phase 1: Create Post ───────────────────────────────────────
    rect rgb(224, 242, 254)
        Note over User,DB: Phase 1 — Create Post

        User ->>+ FE : Enter content, attach media (optional), click "Post"
        FE ->>+ BE : POST /api/posts (multipart/form-data)<br/>{ desc, imgType, isSensitive?, file[] }
        Note over BE : JwtAuthGuard + EmailVerifiedGuard

        alt Has attached files
            BE ->> BE : Upload files to Cloudinary → get Secure URLs
        end

        BE ->>+ DB : post.create({ desc, userId, media[], isSensitive })
        DB -->>- BE : Post record

        BE ->> DB : Parse #hashtags → upsert Hashtag + PostTag<br/>Parse @mentions → mention.createMany + emit MENTION notification

        BE -->>- FE : 201 Created — { post }
        FE -->>- User: Post appears on feed
    end

    %% ── Phase 2: Edit Post ─────────────────────────────────────────
    rect rgb(236, 253, 245)
        Note over User,DB: Phase 2 — Edit Post

        User ->>+ FE : Click "Edit post" → EditPostModal opens
        User ->> FE : Edit content / media → click "Save"
        FE ->>+ BE : PATCH /api/posts/{id} (multipart/form-data)<br/>{ desc, mediaIdsToRemove?, file[]? }
        Note over BE : JwtAuthGuard + BannedUserGuard + EmailVerifiedGuard

        BE ->>+ DB : post.findUnique({ id }) — check ownership
        DB -->>- BE : Post record

        alt Not found or not owner
            BE -->> FE : 404 / 403
            FE -->> User: Show error
        else Valid
            BE ->> BE : Delete old media from Cloudinary (if any)<br/>Upload new media to Cloudinary (if any)
            BE ->> DB : postMedia.deleteMany / createMany<br/>post.update({ desc })<br/>Update hashtags & mentions
            BE -->>- FE : 200 OK — { post }
            FE -->>- User: Post shows "(edited)"
        end
    end

    %% ── Phase 3: Delete Post ───────────────────────────────────────
    rect rgb(255, 247, 237)
        Note over User,DB: Phase 3 — Delete Post

        User ->>+ FE : Click "Delete post" on dropdown
        FE ->>+ BE : DELETE /api/posts/{id}
        Note over BE : JwtAuthGuard + BannedUserGuard

        BE ->>+ DB : post.findUnique({ id }) — check ownership
        DB -->>- BE : Post record

        alt Not found or not owner
            BE -->> FE : 404 / 403
            FE -->> User: Show error (revert optimistic update)
        else Valid
            BE ->> DB : post.update({ deletedAt: now() }) — soft delete
            BE -->>- FE : 200 OK — { success: true }
            FE -->>- User: Post disappears from feed
        end
    end