sequenceDiagram
    autonumber
    actor       Admin      as Admin
    participant FE         as Frontend<br/>(Next.js)
    participant BE         as Backend<br/>(NestJS)
    participant DB         as Database
    actor       BannedUser as Banned User

    %% ── Phase 1: User Account Moderation (Banning/Unbanning) ──────
    rect rgb(239, 246, 255)
        Note over Admin,BannedUser: Phase 1 — User Account Moderation (Banning/Unbanning)

        Admin ->>+ FE : Click Ban / Unban button on user row
        FE ->>+ BE : POST /api/admin/users/:id/ban (or unban)
        Note over BE : JwtAuthGuard + RolesGuard (role: 'ADMIN')

        BE ->>+ DB : Check target user existence (prisma.user.findUnique)
        DB -->>- BE : User record or null

        BE ->>+ DB : Update user banned status (banned: true/false)
        DB -->>- BE : Update success

        BE -) BannedUser : Emit 'accountBanned' event via WS (if banned)

        BE -->>- FE : 200 OK — { ok: true }
        FE ->> FE : router.refresh() (reloads active dashboard view)
        FE -->>- Admin : Render updated user row & state
    end

    %% ── Phase 2: Resolving Content Reports (Dismissing Reports) ───
    rect rgb(240, 253, 244)
        Note over Admin,DB: Phase 2 — Dismissing Content Reports

        Admin ->>+ FE : Click Dismiss button on report row
        FE ->>+ BE : POST /api/admin/reports/:id/dismiss
        Note over BE : JwtAuthGuard + RolesGuard (role: 'ADMIN')

        BE ->>+ DB : Check report existence (prisma.report.findUnique)
        DB -->>- BE : Report record or null

        BE ->>+ DB : Update report status to 'CLOSED'
        DB -->>- BE : Report closed in database

        BE -->>- FE : 200 OK — { ok: true }
        FE ->> FE : router.refresh()
        FE -->>- Admin : Remove report row from active list
    end

    %% ── Phase 3: Resolving Content Reports (Deleting Reported Post) 
    rect rgb(254, 243, 199)
        Note over Admin,DB: Phase 3 — Deleting Reported Content

        Admin ->>+ FE : Click Delete Post button on report row
        FE ->>+ BE : DELETE /api/admin/reports/:id/delete-post
        Note over BE : JwtAuthGuard + RolesGuard (role: 'ADMIN')

        BE ->>+ DB : Check report existence (prisma.report.findUnique)
        DB -->>- BE : Report record or null

        BE ->>+ DB : Update reported post (deletedAt = new Date())
        DB -->>- BE : Post soft-deleted in Database

        BE ->>+ DB : Update report status to 'CLOSED'
        DB -->>- BE : Report closed in Database

        BE -->>- FE : 200 OK — { ok: true }
        FE ->> FE : router.refresh()
        FE -->>- Admin : Remove report from queue & remove post from UI feed
    end
