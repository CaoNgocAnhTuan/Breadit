sequenceDiagram
    autonumber
    actor User as User
    participant FE as Frontend<br/>(Next.js)
    participant BE as Backend<br/>(NestJS)
    participant DB as Database
    participant Mail as Mail Service

    %% ── Phase 1: Registration ──────────────────────────────────────
    rect rgb(224, 242, 254)
        Note over User,Mail: Phase 1 — Account Registration
        User ->>+ FE : Fill & submit registration form
        FE ->> FE : Client-side validation
        FE ->>+ BE : POST /api/auth/register
        BE ->>+ DB : Check duplicate email / username
        DB -->>- BE : User record / null
        alt Duplicate
            BE -->> FE : 409 Conflict
            FE -->> User: Show duplicate account error
        else Unique
            BE ->> BE : bcrypt.hash(password, 10)
            BE ->> DB : Save new user
            BE ->> DB : Delete old OTP & save new OTP (15 min)
            BE ->>+ Mail: Send verification email (OTP code)
            Mail -->>- BE : Email delivered
            BE -->>- FE : 201 Created — { userId }
            FE -->>- User: Redirect to /verify?email=...
        end
    end

    %% ── Phase 2: Email Verification ────────────────────────────────
    rect rgb(236, 253, 245)
        Note over User,Mail: Phase 2 — Email Verification (OTP)
        User ->>+ FE : Input 6-digit OTP & submit
        FE ->>+ BE : POST /api/auth/verify { email, code }
        BE ->>+ DB : Query VerificationToken by email & OTP
        DB -->>- BE : Token record / null
        alt Not found or expired
            BE ->> DB : Delete expired token
            BE -->> FE : 400 Bad Request — Invalid/expired code
            FE -->> User: Show error + Resend option
        else Valid
            BE ->> DB : Delete consumed OTP
            BE ->> DB : user.update({ emailVerified: now })
            BE -->>- FE : 200 OK
            FE -->>- User: Redirect to /sign-in?verified=1
        end
    end

    %% ── Phase 3: Login ─────────────────────────────────────────────
    rect rgb(255, 247, 237)
        Note over User,DB: Phase 3 — User Authentication (Login)
        User ->>+ FE : Input credentials & submit
        FE ->>+ BE : POST /api/auth/login { email, password }
        BE ->>+ DB : Query user by email
        DB -->>- BE : { hashedPassword, emailVerified, role, banned }
        alt Not found or wrong password
            BE -->> FE : 401 Unauthorized
            FE -->> User: Show invalid credentials error
        else Credentials valid
            BE ->> BE : bcrypt.compare → signJwt → Set-Cookie (30d)
            BE -->>- FE : 200 OK — { user }
            FE ->>- FE : router.push("/")
            alt Banned
                FE -->> User: Render suspension page (SSR)
            else Active
                FE -->> User: Render Home Feed (/)
            end
        end
    end