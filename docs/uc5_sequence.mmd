sequenceDiagram
    autonumber
    actor       User as User
    participant FE    as Frontend<br/>(Next.js)
    participant BE    as Backend<br/>(NestJS)
    participant DB    as Database

    %% ── Phase 1: Follow / Unfollow Profile ─────────────────────────
    rect rgb(224, 242, 254)
        Note over User,DB: Phase 1 — Follow / Unfollow Profile

        User ->>+ FE : Click Follow / Unfollow button
        FE ->>+ BE : POST /api/users/:id/follow
        Note over BE : JwtAuthGuard + BannedUserGuard (optimistic UI update)

        BE ->>+ DB : Query existing follow relation (prisma.follow.findFirst)
        DB -->>- BE : Follow record or null

        BE ->>+ DB : Create or delete follow record in Database
        DB -->>- BE : Mutation success (toggle follow state)

        BE ->> BE : Invalidate cache (follows graph, user stats)
        BE -) BE : notificationsService.emit('FOLLOW') (if followed)

        BE -->>- FE : 200 OK — { following: boolean }
        FE ->> FE : router.refresh()
        FE -->>- User : Update follow button & follower count
    end

    %% ── Phase 2: Block / Unblock User ──────────────────────────────
    rect rgb(236, 253, 245)
        Note over User,DB: Phase 2 — Block / Unblock User

        User ->>+ FE : Click Block / Unblock in profile dropdown
        FE ->>+ BE : POST /api/users/:id/block
        Note over BE : JwtAuthGuard + BannedUserGuard (optimistic UI update)

        BE ->>+ DB : Query existing block status (prisma.block.findFirst)
        DB -->>- BE : Block record or null

        BE ->>+ DB : Toggle block record (create block + remove mutual follows OR delete block)
        DB -->>- BE : Toggle status (blocked: boolean)

        BE ->> BE : Invalidate cache (blocked users, follows graph, user stats)

        BE -->>- FE : 200 OK — { blocked: boolean }
        FE ->> FE : Invalidate queries ["posts", "profile-posts"] + router.refresh()
        FE -->>- User : Update block status, refresh profile & feed visibility
    end
