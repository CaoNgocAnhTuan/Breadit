{
  "name": "breadit",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev":       "npm run dev -w @breadit/frontend",
    "build":     "npm run build -w @breadit/frontend",
    "start":     "npm run start -w @breadit/frontend",
    "lint":      "npm run lint -w @breadit/frontend",
    "typecheck": "npm run typecheck -w @breadit/frontend",
    "dev:reset": "npm run dev:reset -w @breadit/frontend",
    "dataset:humans": "powershell -ExecutionPolicy Bypass -File scripts/dataset-humans.ps1",
    "prepare":   "husky"
  },
  "lint-staged": {
    "apps/frontend/src/**/*.{ts,tsx,js,jsx}": "eslint --fix --config apps/frontend/eslint.config.mjs"
  },
  "prisma": {
    "seed": "ts-node --project apps/backend/tsconfig.json apps/backend/prisma/seed.ts"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
